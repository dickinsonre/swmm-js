; OWA SWMM Example 7 – Dual Drainage (Major/Minor System)
; Source: OpenWaterAnalytics SWMM test suite / EPA SWMM 5 Example 7
; Tests:  Overland flow on streets (major system), inlet capture, pipe surcharge

[TITLE]
Example 7 – Dual Drainage System
Models interaction between a minor pipe system and major overland
flow conveyance on streets. Inlets capture flow from gutters.

[OPTIONS]
FLOW_UNITS           CFS
INFILTRATION         HORTON
FLOW_ROUTING         DYNWAVE
LINK_OFFSETS         DEPTH
MIN_SLOPE            0
ALLOW_PONDING        YES
SKIP_STEADY_STATE    NO
START_DATE           06/01/2007
START_TIME           00:00:00
REPORT_START_DATE    06/01/2007
REPORT_START_TIME    00:00:00
END_DATE             06/01/2007
END_TIME             06:00:00
SWEEP_START          01/01
SWEEP_END            12/31
DRY_DAYS             0
REPORT_STEP          00:05:00
WET_STEP             00:02:00
DRY_STEP             01:00:00
ROUTING_STEP         0:00:15

[RAINGAGES]
;;Name  Format    Interval  SCF  Source    SeriesName
RG1     INTENSITY 0:05      1.0  TIMESERIES TS_RAIN

[SUBCATCHMENTS]
;;Name   RainGage  Outlet   Area   %Imperv  Width  %Slope  CurbLen
Block_NW RG1       Gutter1  0.5    85       150    1.0     300
Block_NE RG1       Gutter2  0.5    85       150    1.0     300
Block_SW RG1       Gutter3  0.5    85       150    1.0     300
Block_SE RG1       Gutter4  0.5    85       150    1.0     300
; Pervious open space draining directly to minor system
Park     RG1       MJ1      1.2    15       200    0.5     0

[SUBAREAS]
Block_NW  0.011  0.20  0.05  0.10  25  OUTLET
Block_NE  0.011  0.20  0.05  0.10  25  OUTLET
Block_SW  0.011  0.20  0.05  0.10  25  OUTLET
Block_SE  0.011  0.20  0.05  0.10  25  OUTLET
Park      0.011  0.15  0.05  0.10  25  OUTLET

[INFILTRATION]
Block_NW  3.0  0.5  4.14  7  0
Block_NE  3.0  0.5  4.14  7  0
Block_SW  3.0  0.5  4.14  7  0
Block_SE  3.0  0.5  4.14  7  0
Park      3.0  0.5  4.14  7  0

; ── MINOR (pipe) system ────────────────────────────────────────────────
[JUNCTIONS]
;;Name   Elev   MaxDepth  InitDepth  SurDepth  Ponded
MJ1      5.0    8         0          0         500
MJ2      4.5    8         0          0         500
MJ3      4.0    8         0          0         500
MJ4      3.5    8         0          0         500

[OUTFALLS]
Out_Minor  3.0  FREE  NO

[CONDUITS]
;;Name   From   To     Length  Rough  InOffset  OutOffset  InitFlow  MaxFlow
MC1      MJ1    MJ2    200     0.013  0         0          0         0
MC2      MJ2    MJ3    200     0.013  0         0          0         0
MC3      MJ3    MJ4    200     0.013  0         0          0         0
MC4      MJ4    Out_Minor 100  0.013  0         0          0         0

[XSECTIONS]
MC1  CIRCULAR  1.0  0  0  0  1
MC2  CIRCULAR  1.0  0  0  0  1
MC3  CIRCULAR  1.25 0  0  0  1
MC4  CIRCULAR  1.25 0  0  0  1

; ── MAJOR (surface/gutter) system ─────────────────────────────────────
; Gutters modelled as wide shallow open channels
[JUNCTIONS]
;;Name    Elev   MaxDepth  InitDepth  SurDepth  Ponded
Gutter1   5.1    0.5       0          0         0
Gutter2   5.1    0.5       0          0         0
Gutter3   5.0    0.5       0          0         0
Gutter4   5.0    0.5       0          0         0
Inlet1    5.05   0.5       0          0         0
Inlet2    5.05   0.5       0          0         0

[CONDUITS]
;;Gutter reaches
GC1  Gutter1  Inlet1  100  0.016  0  0  0  0
GC2  Gutter2  Inlet1  100  0.016  0  0  0  0
GC3  Gutter3  Inlet2  100  0.016  0  0  0  0
GC4  Gutter4  Inlet2  100  0.016  0  0  0  0

[XSECTIONS]
;;Gutter cross sections – wide, shallow
GC1  TRAPEZOIDAL  0.33  20  1.5  1.5  0
GC2  TRAPEZOIDAL  0.33  20  1.5  1.5  0
GC3  TRAPEZOIDAL  0.33  20  1.5  1.5  0
GC4  TRAPEZOIDAL  0.33  20  1.5  1.5  0

; ── Inlet capture – orifices connecting major→minor ───────────────────
[ORIFICES]
;;Name    From    To    Type    Offset  Cd    Gated
Inlet_A   Inlet1  MJ1   SIDE    0.0     0.65  NO
Inlet_B   Inlet2  MJ2   SIDE    0.0     0.65  NO

[XSECTIONS]
Inlet_A  RECT_CLOSED  0.33  1.5  0  0
Inlet_B  RECT_CLOSED  0.33  1.5  0  0

[TIMESERIES]
;;Name    Date  Time   Value (in/hr)
TS_RAIN         0:00   0.00
TS_RAIN         0:30   1.50
TS_RAIN         1:00   3.00
TS_RAIN         1:30   5.00
TS_RAIN         2:00   3.00
TS_RAIN         2:30   1.50
TS_RAIN         3:00   0.00
TS_RAIN         6:00   0.00

[REPORT]
INPUT      NO
CONTROLS   NO
SUBCATCHMENTS ALL
NODES      ALL
LINKS      ALL

[MAP]
DIMENSIONS  0.00  0.00  10000.00  10000.00
Units       None

[COORDINATES]
MJ1       3000  5000
MJ2       4500  5000
MJ3       6000  5000
MJ4       7500  5000
Out_Minor 8500  5000
Gutter1   2000  6500
Gutter2   4000  6500
Gutter3   2000  3500
Gutter4   4000  3500
Inlet1    3000  6500
Inlet2    3000  3500

[VERTICES]

[POLYGONS]
Block_NW  1000  7000
Block_NW  2500  7000
Block_NW  2500  5500
Block_NW  1000  5500
Block_NE  3500  7000
Block_NE  5000  7000
Block_NE  5000  5500
Block_NE  3500  5500
Block_SW  1000  4500
Block_SW  2500  4500
Block_SW  2500  3000
Block_SW  1000  3000
Block_SE  3500  4500
Block_SE  5000  4500
Block_SE  5000  3000
Block_SE  3500  3000
Park      5500  6000
Park      7500  6000
Park      7500  4000
Park      5500  4000
