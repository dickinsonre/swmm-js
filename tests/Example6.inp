; OWA SWMM Example 6 – Snowmelt and Groundwater
; Source: OpenWaterAnalytics SWMM test suite / EPA SWMM 5 Example 6
; Tests:  Snow accumulation/melt parameters, aquifer/groundwater interaction

[TITLE]
Example 6 – Snowmelt and Groundwater
Continuous simulation with snowmelt, aquifer recharge, and groundwater
contribution to sewer inflows.

[OPTIONS]
FLOW_UNITS           CFS
INFILTRATION         GREEN_AMPT
FLOW_ROUTING         DYNWAVE
LINK_OFFSETS         DEPTH
MIN_SLOPE            0
ALLOW_PONDING        NO
SKIP_STEADY_STATE    NO
START_DATE           01/01/2007
START_TIME           00:00:00
REPORT_START_DATE    04/01/2007
REPORT_START_TIME    00:00:00
END_DATE             06/01/2007
END_TIME             00:00:00
SWEEP_START          01/01
SWEEP_END            12/31
DRY_DAYS             0
REPORT_STEP          01:00:00
WET_STEP             00:15:00
DRY_STEP             04:00:00
ROUTING_STEP         0:05:00

[RAINGAGES]
;;Name  Format    Interval  SCF  Source    SeriesName
RG1     VOLUME    1:00      1.3  TIMESERIES TS_PRECIP

[TEMPERATURE]
;;Data Source  Parameters
TIMESERIES TS_TEMP

[EVAPORATION]
MONTHLY  0.0  0.0  0.0  0.1  0.2  0.35  0.4  0.35  0.2  0.1  0.0  0.0
DRY_ONLY NO

[SNOWMELT]
;;Dividing Temp  ATI-Wt  Neg-Melt-Ratio  SW-Elev  Adj-Lat  Base-Temp
32               0.5     0.6             0        0        32

[SNOWPACKS]
;;Name        Surface    Parameters...
SP1           PLOWABLE   0.001  0.001  32.0  0.10  0.0  0.0  0.00
SP1           IMPERVIOUS 0.001  0.001  32.0  0.10  0.0  0.0  0.10
SP1           PERVIOUS   0.001  0.001  32.0  0.10  0.0  0.0  0.10
SP1           REMOVAL    1      0      0     0     0    0    0    0

[AQUIFERS]
;;Name    Por   WP    FC    Ksat   Kslope  Tslope  ETu  ETs  Seep  Ebot  Egw  Umc
Aq1       0.5   0.15  0.30  1.2    10.0    15.0    0.35 14   0.002 0     5.0  0.30

[GROUNDWATER]
;;Subcat  Aquifer  Node  Esurf  A1    B1    A2    B2    A3    Dsw   Egwt  Ebot  Wgr  Umc
S1        Aq1      J1    100    0.001 1.5   0     0     0     0     3.0
S2        Aq1      J2    95     0.001 1.5   0     0     0     0     3.0

[SUBCATCHMENTS]
;;Name  RainGage  Outlet  Area  %Imperv  Width  %Slope  CurbLen  SnowPack
S1      RG1       J1      40    35       700    0.5     0        SP1
S2      RG1       J2      30    30       600    0.5     0        SP1

[SUBAREAS]
;;Subcat  NImperv  NPerv  SImperv  SPerv  PctZero  RouteTo
S1        0.012    0.10   0.06     0.06   25       OUTLET
S2        0.012    0.10   0.06     0.06   25       OUTLET

[INFILTRATION]
;;Subcat  Suction  Ksat   IMD
S1        3.5      0.52   0.26
S2        3.5      0.52   0.26

[JUNCTIONS]
;;Name  Elev  MaxDepth  InitDepth  SurDepth  Ponded
J1      3.0   12        0          0         0
J2      2.0   12        0          0         0
J3      1.0   12        0          0         0

[OUTFALLS]
;;Name  Elev  Type  StageData  TideGate
Out1    0.0   FREE             NO

[CONDUITS]
;;Name  From  To    Length  Rough  InOffset  OutOffset  InitFlow  MaxFlow
C1      J1    J2    500     0.013  0         0          0         0
C2      J2    J3    400     0.013  0         0          0         0
C3      J3    Out1  200     0.013  0         0          0         0

[XSECTIONS]
;;Link  Shape     Geom1  Geom2  Geom3  Geom4  Barrels
C1      CIRCULAR  2.0    0      0      0      1
C2      CIRCULAR  2.0    0      0      0      1
C3      CIRCULAR  2.0    0      0      0      1

[TIMESERIES]
;;Name     Date       Time   Value
TS_PRECIP  01/01/2007 0:00   0.10
TS_PRECIP  01/15/2007 0:00   0.15
TS_PRECIP  02/01/2007 0:00   0.08
TS_PRECIP  03/01/2007 0:00   0.12
TS_PRECIP  04/01/2007 0:00   0.20
TS_PRECIP  05/01/2007 0:00   0.18
TS_PRECIP  06/01/2007 0:00   0.00
TS_TEMP    01/01/2007 0:00   28.0
TS_TEMP    02/01/2007 0:00   30.0
TS_TEMP    03/01/2007 0:00   36.0
TS_TEMP    04/01/2007 0:00   48.0
TS_TEMP    05/01/2007 0:00   58.0
TS_TEMP    06/01/2007 0:00   65.0

[REPORT]
INPUT      NO
CONTROLS   NO
SUBCATCHMENTS ALL
NODES      ALL
LINKS      ALL

[MAP]
DIMENSIONS  0.00  0.00  10000.00  10000.00
Units       None

