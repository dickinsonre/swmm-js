; OWA SWMM Example 3 – Combined Sewer Overflow (CSO) with RDII
; Source: OpenWaterAnalytics SWMM test suite / EPA SWMM 5 Example 3
; Tests:  Dry-weather flow patterns, RDII unit hydrographs, CSO node

[TITLE]
Example 3 – Combined Sewer System with RDII
Models dry-weather flow and rainfall-dependent infiltration/inflow (RDII)
in a combined sewer network with a CSO structure.

[OPTIONS]
FLOW_UNITS           CFS
INFILTRATION         HORTON
FLOW_ROUTING         DYNWAVE
LINK_OFFSETS         DEPTH
MIN_SLOPE            0
ALLOW_PONDING        NO
SKIP_STEADY_STATE    NO
START_DATE           01/01/2007
START_TIME           00:00:00
REPORT_START_DATE    01/01/2007
REPORT_START_TIME    00:00:00
END_DATE             01/01/2007
END_TIME             24:00:00
SWEEP_START          01/01
SWEEP_END            12/31
DRY_DAYS             5
REPORT_STEP          00:15:00
WET_STEP             00:05:00
DRY_STEP             01:00:00
ROUTING_STEP         0:00:30

[RAINGAGES]
;;Name  Format    Interval  SCF  Source    SeriesName
RG1     VOLUME    0:15      1.0  TIMESERIES TS_RAIN

[SUBCATCHMENTS]
;;Name  RainGage  Outlet  Area  %Imperv  Width  %Slope  CurbLen
S1      RG1       J1      30    45       600    0.5     0
S2      RG1       J2      20    40       400    0.5     0
S3      RG1       J3      25    55       500    0.5     0

[SUBAREAS]
;;Subcat  NImperv  NPerv  SImperv  SPerv  PctZero  RouteTo
S1        0.01     0.10   0.05     0.05   25       OUTLET
S2        0.01     0.10   0.05     0.05   25       OUTLET
S3        0.01     0.10   0.05     0.05   25       OUTLET

[INFILTRATION]
;;Subcat  MaxRate  MinRate  Decay  DryTime  MaxInfil
S1        3.0      0.5      4.14   7        0
S2        3.0      0.5      4.14   7        0
S3        3.0      0.5      4.14   7        0

[JUNCTIONS]
;;Name  Elev  MaxDepth  InitDepth  SurDepth  Ponded
J1      5.0   12        0          0         0
J2      4.0   12        0          0         0
J3      3.0   12        0          0         0
J4      2.0   12        0          0         0
JCSO    1.0   14        0          2.0       500

[OUTFALLS]
;;Name    Elev   Type   StageData  TideGate
Out_STP   0.0    FREE              NO
Out_CSO   0.0    FREE              NO

[CONDUITS]
;;Name  From   To    Length  Rough  InOffset  OutOffset  InitFlow  MaxFlow
C1      J1     J2    400     0.013  0         0          0         0
C2      J2     J3    350     0.013  0         0          0         0
C3      J3     J4    300     0.013  0         0          0         0
C4      J4     JCSO  200     0.013  0         0          0         0
C5      JCSO  Out_STP 100   0.013  0         0          0         0

[WEIRS]
;;Name   From  To        Type       CrestHt  Cd    Gated  EndCon  EndCoeff
CSO_Weir JCSO  Out_CSO   TRANSVERSE 2.0      3.33  NO     0       0

[XSECTIONS]
;;Link     Shape     Geom1  Geom2  Geom3  Geom4  Barrels
C1         CIRCULAR  1.5    0      0      0      1
C2         CIRCULAR  1.5    0      0      0      1
C3         CIRCULAR  2.0    0      0      0      1
C4         CIRCULAR  2.0    0      0      0      1
C5         CIRCULAR  2.0    0      0      0      1
CSO_Weir   RECT_OPEN 1.0    5.0    0      0

[DWF]
;;Node  Constituent  AvgValue  Pat1        Pat2
J1      FLOW         0.5       HOURLY_PAT
J2      FLOW         0.3       HOURLY_PAT
J3      FLOW         0.4       HOURLY_PAT

[PATTERNS]
;;Name       Type     Multipliers …
HOURLY_PAT   HOURLY   0.5 0.5 0.6 0.6 0.7 0.9
HOURLY_PAT            1.1 1.2 1.3 1.2 1.1 1.0
HOURLY_PAT            0.9 0.8 0.8 0.8 0.9 1.0
HOURLY_PAT            1.1 1.2 1.3 1.1 0.9 0.7

[HYDROGRAPHS]
;;UHG Name  Rain Gage
UHG1        RG1
;;         Month  Short-R  Short-T  Short-K  Med-R   Med-T  Med-K  Long-R  Long-T  Long-K
UHG1       ALL    0.050    1.0      2.0      0.030   2.0    3.0    0.020   4.0     5.0

[RDII]
;;Node  UHG Group  Sewer Area (ac)
J1      UHG1       15
J2      UHG1       10
J3      UHG1       12

[TIMESERIES]
;;Name     Date  Time   Value
TS_RAIN          0:00   0.00
TS_RAIN          0:30   0.00
TS_RAIN          2:00   0.25
TS_RAIN          2:15   0.50
TS_RAIN          2:30   0.75
TS_RAIN          2:45   0.50
TS_RAIN          3:00   0.25
TS_RAIN          3:15   0.00
TS_RAIN         24:00   0.00

[REPORT]
INPUT      NO
CONTROLS   NO
SUBCATCHMENTS ALL
NODES      ALL
LINKS      ALL

[MAP]
DIMENSIONS  0.00  0.00  10000.00  10000.00
Units       None

[COORDINATES]
;;Node    X-Coord  Y-Coord
J1        1000     5000
J2        2500     5000
J3        4000     5000
J4        5500     5000
JCSO      7000     5000
Out_STP   8500     5000
Out_CSO   7000     3500

[VERTICES]

[POLYGONS]
S1  500   5500
S1  1500  5500
S1  1500  4500
S1  500   4500
S2  2000  5500
S2  3000  5500
S2  3000  4500
S2  2000  4500
S3  3500  5500
S3  4500  5500
S3  4500  4500
S3  3500  4500
